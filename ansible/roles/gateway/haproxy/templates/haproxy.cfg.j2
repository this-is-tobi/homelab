global
  log stdout format raw local0 info
  # Security: drop privileges after binding
  maxconn 4096
  # Performance: use multi-threaded mode (auto-detect CPUs)
  nbthread 2

defaults
  mode tcp
  log global
  option tcplog
  option dontlognull
  # Timeouts tuned for mixed traffic (websockets, API, file uploads)
  timeout connect 5s
  timeout client  60s
  timeout server  60s
  timeout client-fin 30s
  timeout tunnel  3600s
  timeout http-request 10s
  timeout http-keep-alive 5s
  timeout queue 30s
  # Retry on connection failure
  retries 3
  option redispatch

# --- Stats (restricted to local/VPN) ---
frontend stats
  mode http
  bind *:8404
  acl allowed_stats src 127.0.0.0/8 {{ (gatewayIp + '/255.255.0.0') | ansible.utils.ipaddr('network/prefix') }} {{ haproxy.allowedIps }}
  http-request deny if !allowed_stats
  stats enable
  stats uri /
  stats refresh 30s
  stats show-legends
  stats hide-version
{% if haproxy.statsPassword is defined and haproxy.statsPassword != '' %}
  stats auth admin:{{ haproxy.statsPassword }}
{% endif %}

# --- Web traffic (HTTP/HTTPS) ---
{# Ingress backend selection (kept generic for future controller changes):
   - haproxy.traefikHosts / traefikHostSuffixes route selected SNIs to the
     traefik backend (node:traefikHttpsPort); everything else hits the
     default ingress backend.
   - haproxy.ingressDefault selects the default backend (port 80 +
     unmatched SNIs): 'traefik' = node:traefikHttp(s)Port, anything else =
     the legacy node:80/443.
   With no vars set, this template renders plain node:80/443 routing. #}
{% set traefik_sni_hosts = haproxy.traefikHosts | default([]) %}
{% set traefik_sni_suffixes = haproxy.traefikHostSuffixes | default([]) %}
{% set traefik_http_port = haproxy.traefikHttpPort | default(8080) %}
{% set traefik_https_port = haproxy.traefikHttpsPort | default(8443) %}
{% set default_is_traefik = (haproxy.ingressDefault | default('apisix')) == 'traefik' %}
{% set default_http_port = traefik_http_port if default_is_traefik else 80 %}
{% set default_https_port = traefik_https_port if default_is_traefik else 443 %}
{% set traefik_sni_routing = (traefik_sni_hosts | length > 0) or (traefik_sni_suffixes | length > 0) %}
frontend homelab_entrypoint_lb
  bind *:80
  bind *:443
  # Rate-limit: max 100 concurrent connections per source IP
  stick-table type ip size 100k expire 30s store conn_cur
  acl too_many_conns sc0_conn_cur gt 100
  tcp-request connection track-sc0 src
  tcp-request connection reject if too_many_conns
  # Route port 80 (plain HTTP) and port 443 (TLS) to the ingress controller
  acl is_https dst_port 443
{% if traefik_sni_routing %}
  # Wait for the TLS ClientHello on 443 to read the SNI (plain HTTP on 80 is
  # accepted immediately and never waits on the inspect-delay).
  tcp-request inspect-delay 5s
  tcp-request content accept if !is_https
  tcp-request content accept if { req_ssl_hello_type 1 }
{% if traefik_sni_hosts | length > 0 %}
  acl sni_traefik req_ssl_sni -i {{ traefik_sni_hosts | join(' ') }}
{% endif %}
{% if traefik_sni_suffixes | length > 0 %}
  acl sni_traefik req_ssl_sni -i -m end {{ traefik_sni_suffixes | join(' ') }}
{% endif %}
  use_backend traefik_entrypoint_https if is_https sni_traefik
{% endif %}
  use_backend homelab_entrypoint_https if is_https
  default_backend homelab_entrypoint_http

# --- Kubernetes API (restricted access) ---
frontend k3s_api_server_lb
  bind *:6443
  acl white_list src {{ (gatewayIp + '/255.255.0.0') | ansible.utils.ipaddr('network/prefix') }} {{ haproxy.extraKubeAllowedIps }}
  tcp-request connection reject if !white_list
  default_backend k3s_api_server

# --- Backends ---

# HTTP (port 80): plain HTTP to the default ingress controller, which
# redirects to HTTPS. Workers preferred; masters as backup.
backend homelab_entrypoint_http
  mode tcp
  balance leastconn
  option tcp-check
  default-server inter 5s downinter 2s rise 2 fall 3 slowstart 30s maxconn 512
{% for host in groups['workers'] %}
  server {{ host }} {{ hostvars[host]['ansible_host'] }}:{{ default_http_port }} check
{% endfor %}
{% for host in groups['masters'] %}
  server {{ host }} {{ hostvars[host]['ansible_host'] }}:{{ default_http_port }} check backup
{% endfor %}

# HTTPS (port 443): TLS passthrough — the ingress controller terminates TLS.
# Use plain TCP check (not check-ssl) because the controllers require SNI, so
# SNI-less health checks cause a handshake failure and mark backends as DOWN.
# Workers preferred; masters as backup.
backend homelab_entrypoint_https
  mode tcp
  balance leastconn
  option tcp-check
  default-server inter 5s downinter 2s rise 2 fall 3 slowstart 30s maxconn 512
{% for host in groups['workers'] %}
  server {{ host }} {{ hostvars[host]['ansible_host'] }}:{{ default_https_port }} check
{% endfor %}
{% for host in groups['masters'] %}
  server {{ host }} {{ hostvars[host]['ansible_host'] }}:{{ default_https_port }} check backup
{% endfor %}
{% if traefik_sni_routing %}

# Traefik (migration): TLS passthrough to the traefik LoadBalancer host port.
backend traefik_entrypoint_https
  mode tcp
  balance leastconn
  option tcp-check
  default-server inter 5s downinter 2s rise 2 fall 3 slowstart 30s maxconn 512
{% for host in groups['workers'] %}
  server {{ host }} {{ hostvars[host]['ansible_host'] }}:{{ traefik_https_port }} check
{% endfor %}
{% for host in groups['masters'] %}
  server {{ host }} {{ hostvars[host]['ansible_host'] }}:{{ traefik_https_port }} check backup
{% endfor %}
{% endif %}

backend k3s_api_server
  mode tcp
  balance roundrobin
  option tcp-check
  default-server inter 5s downinter 2s rise 2 fall 3 maxconn 256
{% for host in groups['masters'] %}
  server {{ host }} {{ hostvars[host]['ansible_host'] }}:6443 check
{% endfor %}
