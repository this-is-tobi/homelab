# Auto-generated by Ansible — custom log acquisition sources
{% set ns = namespace(first=true) %}
{% for source in crowdsec.acquis_files | default(gateway_crowdsec_default_acquis_files) %}
{% if not ns.first %}
---
{% endif %}
{% set ns.first = false %}
filenames:
{% for f in source.filenames %}
  - {{ f }}
{% endfor %}
labels:
  type: {{ source.type }}
# Watches the parent dir for file creation even if the glob matches
# nothing at startup — plain filenames otherwise fail silently once and
# are never retried (see defaults/main.yml).
force_inotify: true
{% endfor %}
{% for container in crowdsec.acquis_docker | default(gateway_crowdsec_default_acquis_docker) %}
{% if not ns.first %}
---
{% endif %}
{% set ns.first = false %}
source: docker
container_name:
  - {{ container.name }}
labels:
  type: {{ container.type }}
{% endfor %}
